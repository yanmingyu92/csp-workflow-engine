{
  "name": "csp-sdtm-ae-mapper",
  "description": "Map adverse event data to SDTM AE domain with MedDRA coding",
  "version": "1.0.0",
  "author": "csp-workflow-engine",
  "tags": ["csp", "layer-2", "sdtm", "ae", "adverse-events", "safety"],
  "entry": "SKILL.md",
  "layer": 2,
  "graph_node": "sdtm-ae-mapping",
  "platform_hints": {"claude-code": {"context": "fork", "model": "sonnet"}},
  "triggers": ["AE", "adverse event", "AETERM", "AEDECOD", "MedDRA", "treatment-emergent", "SAE"],
  "dependencies": ["raw-data-validation", "spec-creation"],
  "produces": ["output/sdtm/ae.xpt"],
  "consumes": ["data/raw/ae.csv", "specs/sdtm-mapping-spec.yaml"]
}
