{
  "name": "csp-sdtm-vs-mapper",
  "description": "Map vital signs to SDTM VS domain",
  "version": "1.0.0",
  "author": "csp-workflow-engine",
  "tags": [
    "csp",
    "layer-2",
    "sdtm",
    "vs"
  ],
  "entry": "SKILL.md",
  "layer": 2,
  "graph_node": "sdtm-vs-mapping",
