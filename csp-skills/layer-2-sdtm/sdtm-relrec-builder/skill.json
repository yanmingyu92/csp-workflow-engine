{
  "name": "csp-sdtm-relrec-builder",
  "description": "Build RELREC dataset for cross-domain record relationships",
  "version": "1.0.0",
  "author": "csp-workflow-engine",
  "tags": [
    "csp",
    "layer-2",
    "sdtm",
    "relrec"
  ],
  "entry": "SKILL.md",
  "layer": 2,
  "graph_node": "sdtm-relrec",
  "platform_hints": {
    "claude-code": {
      "context": "fork",
      "model": "sonnet"
    }
  },
  "triggers": [
    "RELREC",
    "related records",
    "cross-domain relationship",
    "relationship",
    "relrec.xpt",
    "record linkage"
  ],
  "dependencies": [
    "sdtm-dm-mapping",
    "sdtm-ae-mapping",
    "sdtm-cm-mapping"
  ],
  "produces": [
    "output/sdtm/relrec.xpt"
  ],
  "consumes": [
    "All SDTM domains"
  ]
}