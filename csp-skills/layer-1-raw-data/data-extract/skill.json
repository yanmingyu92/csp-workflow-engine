{
  "name": "csp-data-extract",
  "description": "Extract raw clinical data from EDC system to working format",
  "version": "1.0.0",
  "author": "csp-workflow-engine",
  "tags": ["csp", "layer-1", "raw-data", "extraction", "edc"],
  "entry": "SKILL.md",
